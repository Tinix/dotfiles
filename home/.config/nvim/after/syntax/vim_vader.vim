syn keyword	VimVaderUserAttrbKey   contained	bar	ban[g]	cou[nt]	ra[nge] com[plete]	n[args]	re[gister]
syn keyword	VimVaderUserAttrbCmplt contained	augroup buffer behave color command compiler cscope dir environment event expression file file_in_path filetype function help highlight history locale mapping menu option packadd shellcmd sign syntax syntime tag tag_listfiles user var
syn keyword	VimVaderUserAttrbCmplt contained	custom customlist nextgroup=VimVaderUserAttrbCmpltFunc,vimUserCmdError
syn match	VimVaderUserAttrbCmpltFunc contained	",\%([sS]:\|<[sS][iI][dD]>\)\=\%(\h\w*\%(#\h\w*\)\+\|\h\w*\)"hs=s+1 nextgroup=VimVaderUserCmdError

syn case match
syn match	VimVaderUserAttrbCmplt contained	"custom,\u\w*"

" Lower Priority Comments: after some VimVader commands... {{{2
" =======================
syn match	VimVaderComment	excludenl +\s"[^\-:.%#=*].*$+lc=1	contains=@vimCommentGroup,vimCommentString
syn match	VimVaderComment	+\<endif\s\+".*$+lc=5	contains=@vimCommentGroup,vimCommentString
syn match	VimVaderComment	+\<else\s\+".*$+lc=4	contains=@vimCommentGroup,vimCommentString
syn region	VimVaderCommentString	contained oneline start='\S\s\+"'ms=e	end='"'

" Environment Variables: {{{2
" =====================
syn match	VimVaderEnvvar	"\$\I\i*"
syn match	VimVaderEnvvar	"\${\I\i*}"

" In-String Specials: {{{2
" Try to catch strings, if nothing else matches (therefore it must precede the others!)
"  VimVaderEscapeBrace handles ["]  []"] (ie. "s don't terminate string inside [])
syn region	VimVaderEscapeBrace	oneline   contained transparent start="[^\\]\(\\\\\)*\[\zs\^\=\]\=" skip="\\\\\|\\\]" end="]"me=e-1
syn match	VimVaderPatSepErr	contained	"\\)"
syn match	VimVaderPatSep	contained	"\\|"
syn region	VimVaderPatSepZone	oneline   contained   matchgroup=VimVaderPatSepZ start="\\%\=\ze(" skip="\\\\" end="\\)\|[^\\]['"]"	contains=@vimStringGroup
syn region	VimVaderPatRegion	contained transparent matchgroup=VimVaderPatSepR start="\\[z%]\=(" end="\\)"	contains=@vimSubstList oneline
syn match	VimVaderNotPatSep	contained	"\\\\"
syn cluster	VimVaderStringGroup	contains=VimVaderEscapeBrace,vimPatSep,vimNotPatSep,vimPatSepErr,vimPatSepZone,@Spell
syn region	VimVaderString	oneline keepend	start=+[^a-zA-Z>!\\@]"+lc=1 skip=+\\\\\|\\"+ matchgroup=VimVaderStringEnd end=+"+	contains=@vimStringGroup
syn region	VimVaderString	oneline keepend	start=+[^a-zA-Z>!\\@]'+lc=1 end=+'+
syn region	VimVaderString	oneline	start=+=!+lc=1	skip=+\\\\\|\\!+ end=+!+	contains=@vimStringGroup
syn region	VimVaderString	oneline	start="=+"lc=1	skip="\\\\\|\\+" end="+"	contains=@vimStringGroup
syn region	VimVaderString	oneline	start="\s/\s*\A"lc=1 skip="\\\\\|\\+" end="/"	contains=@vimStringGroup
syn match	VimVaderString	contained	+"[^"]*\\$+	skipnl nextgroup=VimVaderStringCont
syn match	VimVaderStringCont	contained	+\(\\\\\|.\)\{-}[^\\]"+

