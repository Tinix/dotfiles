" =============
syn cluster	VimVaderSubstList	contains=VimVaderPatSep,vimPatRegion,vimPatSepErr,vimSubstTwoBS,vimSubstRange,vimNotation
syn cluster	VimVaderSubstRepList	contains=VimVaderSubstSubstr,vimSubstTwoBS,vimNotation
syn cluster	VimVaderSubstList	add=VimVaderCollection
syn match	VimVaderSubst	"\(:\+\s*\|^\s*\||\s*\)\<\%(\<s\%[ubstitute]\>\|\<sm\%[agic]\>\|\<sno\%[magic]\>\)[:#[:alpha:]]\@!" nextgroup=VimVaderSubstPat
syn match	VimVaderSubst	"\%(^\|[^\\]\)\<s\%[ubstitute]\>[:#[:alpha:]]\@!"	nextgroup=VimVaderSubstPat contained
syn match	VimVaderSubst	"/\zs\<s\%[ubstitute]\>\ze/"		nextgroup=VimVaderSubstPat
syn match	VimVaderSubst	"\(:\+\s*\|^\s*\)s\ze#.\{-}#.\{-}#"		nextgroup=VimVaderSubstPat
syn match	VimVaderSubst1       contained	"\<s\%[ubstitute]\>"	nextgroup=VimVaderSubstPat
syn match	VimVaderSubst2       contained	"s\%[ubstitute]\>"	nextgroup=VimVaderSubstPat
syn region	VimVaderSubstPat     contained	matchgroup=VimVaderSubstDelim start="\z([^a-zA-Z( \t[\]&]\)"rs=s+1 skip="\\\\\|\\\z1" end="\z1"re=e-1,me=e-1	 contains=@vimSubstList	nextgroup=VimVaderSubstRep4	oneline
syn region	VimVaderSubstRep4    contained	matchgroup=VimVaderSubstDelim start="\z(.\)" skip="\\\\\|\\\z1" end="\z1" matchgroup=VimVaderNotation end="<[cC][rR]>" contains=@vimSubstRepList	nextgroup=VimVaderSubstFlagErr	oneline
syn region	VimVaderCollection   contained transparent	start="\\\@<!\[" skip="\\\[" end="\]"	contains=VimVaderCollClass
syn match	VimVaderCollClassErr contained	"\[:.\{-\}:\]"
syn match	VimVaderCollClass    contained transparent	"\%#=1\[:\(alnum\|alpha\|blank\|cntrl\|digit\|graph\|lower\|print\|punct\|space\|upper\|xdigit\|return\|tab\|escape\|backspace\):\]"
syn match	VimVaderSubstSubstr  contained	"\\z\=\d"
syn match	VimVaderSubstTwoBS   contained	"\\\\"
syn match	VimVaderSubstFlagErr contained	"[^< \t\r|]\+" contains=VimVaderSubstFlags
syn match	VimVaderSubstFlags   contained	"[&cegiIpr]\+"

" 'String': {{{2
