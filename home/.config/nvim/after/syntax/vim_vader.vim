syn match	VimVaderUserAttrb	contained	"-count\(=\d\+\)\="	contains=VimVaderNumber,vimOper,vimUserAttrbKey
syn match	VimVaderUserAttrb	contained	"-bang\>"		contains=VimVaderOper,vimUserAttrbKey
syn match	VimVaderUserAttrb	contained	"-bar\>"		contains=VimVaderOper,vimUserAttrbKey
