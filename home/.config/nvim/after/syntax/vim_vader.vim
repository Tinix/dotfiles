" Marks, Registers, Addresses, Filters: {{{2
syn match	VimVaderMark	"'[a-zA-Z0-9]\ze[-+,!]"	nextgroup=VimVaderFilter,vimMarkNumber,vimSubst
syn match	VimVaderMark	"'[<>]\ze[-+,!]"		nextgroup=VimVaderFilter,vimMarkNumber,vimSubst
