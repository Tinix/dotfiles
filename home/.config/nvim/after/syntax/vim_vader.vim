" Numbers {{{2
" =======
syn match VimVaderNumber	"\<\d\+\%(\.\d\+\%([eE][+-]\=\d\+\)\=\)\=" skipwhite nextgroup=VimVaderGlobal,vimSubst,vimCommand,vimComment
syn match VimVaderNumber	"-\d\+\%(\.\d\+\%([eE][+-]\=\d\+\)\=\)\="  skipwhite nextgroup=VimVaderGlobal,vimSubst,vimCommand,vimComment
syn match VimVaderNumber	"\<0[xX]\x\+"		       skipwhite nextgroup=VimVaderGlobal,vimSubst,vimCommand,vimComment
syn match VimVaderNumber	"\%(^\|\A\)\zs#\x\{6}"             	       skipwhite nextgroup=VimVaderGlobal,vimSubst,vimCommand,vimComment

" All VimVaderCommands are contained by VimVaderIsCommand. {{{2
syn match VimVaderCmdSep	"[:|]\+"	skipwhite nextgroup=VimVaderAddress,vimAutoCmd,vimEcho,vimIsCommand,vimExtCmd,vimFilter,vimLet,vimMap,vimMark,vimSet,vimSyntax,vimUserCmd
syn match VimVaderIsCommand	"\<\h\w*\>"	contains=VimVaderCommand
syn match VimVaderVar	      contained	"\<\h[a-zA-Z0-9#_]*\>"
syn match VimVaderVar		"\<[bwglstav]:\h[a-zA-Z0-9#_]*\>"
syn match VimVaderVar	      	"\s\zs&\a\+\>"
syn match VimVaderFBVar      contained   "\<[bwglstav]:\h[a-zA-Z0-9#_]*\>"
syn keyword VimVaderCommand  contained	in

" Insertions And Appends: insert append {{{2
" =======================
syn region VimVaderInsert	matchgroup=VimVaderCommand start="^[: \t]*\(\d\+\(,\d\+\)\=\)\=a\%[ppend]$"		matchgroup=VimVaderCommand end="^\.$""
syn region VimVaderInsert	matchgroup=VimVaderCommand start="^[: \t]*\(\d\+\(,\d\+\)\=\)\=c\%[hange]$"		matchgroup=VimVaderCommand end="^\.$""
syn region VimVaderInsert	matchgroup=VimVaderCommand start="^[: \t]*\(\d\+\(,\d\+\)\=\)\=i\%[nsert]$"		matchgroup=VimVaderCommand end="^\.$""
syn region VimVaderInsert	matchgroup=VimVaderCommand start="^[: \t]*\(\d\+\(,\d\+\)\=\)\=starti\%[nsert]$"	matchgroup=VimVaderCommand end="^\.$""

" Behave! {{{2
" =======
syn match   VimVaderBehave	"\<be\%[have]\>" skipwhite nextgroup=VimVaderBehaveModel,vimBehaveError
syn keyword VimVaderBehaveModel contained	mswin	xterm

" Filetypes {{{2
" =========
syn match   VimVaderFiletype	"\<filet\%[ype]\(\s\+\I\i*\)*"	skipwhite contains=VimVaderFTCmd,vimFTOption,vimFTError
syn keyword VimVaderFTCmd    contained	filet[ype]
syn keyword VimVaderFTOption contained	detect indent off on plugin

" Augroup : VimVaderAugroupError removed because long augroups caused sync'ing problems. {{{2
" ======= : Trade-off: Increasing synclines with slower editing vs augroup END error checking.
syn cluster VimVaderAugroupList	contains=VimVaderAugroup,vimIsCommand,vimUserCmd,vimExecute,vimNotFunc,vimFuncName,vimFunction,vimFunctionError,vimLineComment,vimNotFunc,vimMap,vimSpecFile,vimOper,vimNumber,vimOperParen,vimComment,vimString,vimSubst,vimMark,vimRegister,vimAddress,vimFilter,vimCmplxRepeat,vimComment,vimLet,vimSet,vimAutoCmd,vimRegion,vimSynLine,vimNotation,vimCtrlChar,vimFuncVar,vimContinue,vimSetEqual,vimOption
syn match   VimVaderAugroup	"aug\%[roup]!"	contains=VimVaderAugroupKey
syn keyword VimVaderAugroupKey contained	aug[roup]

" Operators: {{{2
" =========
syn cluster	VimVaderOperGroup	contains=VimVaderEnvvar,vimFunc,vimFuncVar,vimOper,vimOperParen,vimNumber,vimString,vimRegister,vimContinue
syn match	VimVaderOper	"\%#=1\(==\|!=\|>=\|<=\|=\~\|!\~\|>\|<\|=\)[?#]\{0,2}"	skipwhite nextgroup=VimVaderString,vimSpecFile
syn match	VimVaderOper	"\(\<is\|\<isnot\)[?#]\{0,2}\>"			skipwhite nextgroup=VimVaderString,vimSpecFile
syn match	VimVaderOper	"||\|&&\|[-+.!]"				skipwhite nextgroup=VimVaderString,vimSpecFile
syn region	VimVaderOperParen 	matchgroup=VimVaderParenSep	start="(" end=")" contains=@vimOperGroup
syn region	VimVaderOperParen	matchgroup=VimVaderSep		start="{" end="}" contains=@vimOperGroup nextgroup=VimVaderVar,vimFuncVar

" Functions : Tag is provided for those who wish to highlight tagged functions {{{2
" =========
syn cluster	VimVaderFuncList	contains=VimVaderCommand,vimFunctionError,vimFuncKey,Tag,vimFuncSID
syn cluster	VimVaderFuncBodyList	contains=VimVaderAbb,vimAddress,vimAugroupKey,vimAutoCmd,vimCmplxRepeat,vimComment,vimContinue,vimCtrlChar,vimEcho,vimEchoHL,vimExecute,vimIsCommand,vimFBVar,vimFunc,vimFunction,vimFuncVar,vimGlobal,vimHighlight,vimIsCommand,vimLet,vimLineComment,vimMap,vimMark,vimNorm,vimNotation,vimNotFunc,vimNumber,vimOper,vimOperParen,vimRegion,vimRegister,vimSearch,vimSet,vimSpecFile,vimString,vimSubst,vimSynLine,vimUnmap,vimUserCommand
syn match	VimVaderFunction	"\<fu\%[nction]!\=\s\+\%(<[sS][iI][dD]>\|[sSgGbBwWtTlL]:\)\=\%(\i\|[#.]\|{.\{-1,}}\)*\ze\s*("	contains=@vimFuncList nextgroup=VimVaderFuncBody

syn region	VimVaderFuncBody  contained	start="\ze\s*("	matchgroup=VimVaderCommand end="\<\(endf\>\|endfu\%[nction]\>\)"		contains=@vimFuncBodyList
syn match	VimVaderFuncVar   contained	"a:\(\K\k*\|\d\+\)"
syn match	VimVaderFuncSID   contained	"\c<sid>\|\<s:"
syn keyword	VimVaderFuncKey   contained	fu[nction]
syn match	VimVaderFuncBlank contained	"\s\+"

syn keyword	VimVaderPattern   contained	start	skip	end

" Special Filenames, Modifiers, Extension Removal: {{{2
" ===============================================
syn match	VimVaderSpecFile	"<c\(word\|WORD\)>"	nextgroup=VimVaderSpecFileMod,vimSubst
syn match	VimVaderSpecFile	"<\([acs]file\|amatch\|abuf\)>"	nextgroup=VimVaderSpecFileMod,vimSubst
syn match	VimVaderSpecFile	"\s%[ \t:]"ms=s+1,me=e-1	nextgroup=VimVaderSpecFileMod,vimSubst
syn match	VimVaderSpecFile	"\s%$"ms=s+1	nextgroup=VimVaderSpecFileMod,vimSubst
syn match	VimVaderSpecFile	"\s%<"ms=s+1,me=e-1	nextgroup=VimVaderSpecFileMod,vimSubst
