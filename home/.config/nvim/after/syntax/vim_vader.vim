syn match	VimVaderPlainMark contained	"'[a-zA-Z0-9]"
syn match	VimVaderRange	"[`'][a-zA-Z0-9],[`'][a-zA-Z0-9]"	contains=VimVaderMark	skipwhite nextgroup=VimVaderFilter

syn match	VimVaderRegister	'[^,;[{: \t]\zs"[a-zA-Z0-9.%#:_\-/]\ze[^a-zA-Z_":0-9]'
syn match	VimVaderRegister	'\<norm\s\+\zs"[a-zA-Z0-9]'
syn match	VimVaderRegister	'\<normal\s\+\zs"[a-zA-Z0-9]'
syn match	VimVaderRegister	'@"'
syn match	VimVaderPlainRegister contained	'"[a-zA-Z0-9\-:.%#*+=]'

syn match	VimVaderAddress	",\zs[.$]"	skipwhite nextgroup=VimVaderSubst1
syn match	VimVaderAddress	"%\ze\a"	skipwhite nextgroup=VimVaderString,vimSubst1

syn match	VimVaderFilter 		"^!!\=[^"]\{-}\(|\|\ze\"\|$\)"	contains=VimVaderOper,vimSpecFile
syn match	VimVaderFilter contained	"!!\=[^"]\{-}\(|\|\ze\"\|$\)"	contains=VimVaderOper,vimSpecFile

" Complex repeats (:h complex-repeat) {{{2
