syn match	VimVaderUserAttrb	contained	"-register\>"		contains=VimVaderOper,vimUserAttrbKey
if !exists("g:vimsyn_noerror") && !exists("g:vimsyn_nousercmderror")
 syn match	VimVaderUserCmdError	contained	"\S\+\>"
