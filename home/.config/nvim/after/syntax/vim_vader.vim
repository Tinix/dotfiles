syn match	VimVaderUserAttrbError	contained	"-\a\+\ze\s"
syn match	VimVaderUserAttrb	contained	"-nargs=[01*?+]"	contains=VimVaderUserAttrbKey,vimOper
syn match	VimVaderUserAttrb	contained	"-complete="		contains=VimVaderUserAttrbKey,vimOper nextgroup=VimVaderUserAttrbCmplt,vimUserCmdError
